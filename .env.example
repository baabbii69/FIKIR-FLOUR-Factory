# Required lead delivery channel
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=


# Optional but strongly recommended Cloudflare Turnstile protection.
# The VITE_ value is public and must be configured at build time.
VITE_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Optional comma-separated production domains, e.g. https://fikirfoods.et,https://www.fikirfoods.et
# The current Vercel request host is always accepted automatically.
ALLOWED_ORIGINS=

# Optional sanitized operational alert webhook for delivery/Turnstile outages.
LEAD_ALERT_WEBHOOK_URL=
